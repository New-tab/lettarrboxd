# Letterboxd Configuration
# Your Letterboxd url (your username is the part after letterboxd.com/user/)
LETTERBOXD_URL=https://letterboxd.com/yourusernamehere/watchlist/

# Seerr Configuration
# Base URL of your Seerr instance (include http/https and port)
SEERR_API_URL=http://localhost:5055
# API key from Seerr Settings > General
SEERR_API_KEY=your_seerr_api_key_here

# Radarr Configuration
# Required only for watched/diary delete-mode instances
# Base URL of your Radarr instance (include http/https and port)
# RADARR_API_URL=http://localhost:7878
# API key from Radarr Settings > General > Security > API Key
# RADARR_API_KEY=your_radarr_api_key_here
# Optional for legacy direct-Radarr add flows only
# RADARR_QUALITY_PROFILE=HD-1080p
# RADARR_MINIMUM_AVAILABILITY=released
# RADARR_ADD_UNMONITORED=false

# Application Configuration
# Directory for storing application data (persistent storage)
DATA_DIR=/data
# Sentinel file used to gate destructive Radarr deletes
MEDIA_MOUNT_SENTINEL=/mnt/media/.MOUNT_OK
# How often to check for new movies in minutes (minimum 10)
CHECK_INTERVAL_MINUTES=60
# Environment mode (development, production, test)
NODE_ENV=development
# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# Movie Limiting (optional - both must be specified together)
# Number of movies to sync from the configured source
# LETTERBOXD_TAKE_AMOUNT=10
# Strategy for selecting movies (newest or oldest)
# LETTERBOXD_TAKE_STRATEGY=newest

# Dry run mode (true to simulate actions without making changes, false to perform actual operations)
# DRY_RUN=true
